# Azure Speech (required for live transcription)
AZURE_SPEECH_KEY=your_speech_key_here
AZURE_SPEECH_REGION=eastus
# Speech language: auto (en-US + zh-CN, recommended) | en-US | zh-CN | en-US,zh-CN
AZURE_SPEECH_LANGUAGE=auto

# Azure STT: rest (default, reliable) | streaming (experimental WebSocket)
AZURE_SPEECH_MODE=rest

# --- STT post-fix (built-in Reg→RAG; disable with THEMIS_STT_FIXUP=false) ---
# THEMIS_STT_FIXUP=true
# Comma-separated misheard:correct pairs (case-sensitive match uses word boundaries)
# AZURE_SPEECH_CORRECTIONS=Reg:RAG,Regs:RAG,REG:RAG,L L M:LLM,G P T:GPT,GPT4:GPT-4
# AZURE_SPEECH_CORRECTIONS=Reg:RAG,拉格:RAG,瑞格:RAG

# Optional: Azure OpenAI for term glosses & question answers (heuristic works without this)
# FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com
# FOUNDRY_API_KEY=your_foundry_key
# FOUNDRY_DEPLOYMENT=gpt-4o-mini
# THEMIS_ANALYSIS_ENABLED=true

# Windows: optional playback endpoint (name substring or device ID). Default = system default audio output.
# THEMIS_AUDIO_OUTPUT_DEVICE=Voicemeeter Input
# Capture strategy: auto (process loopback, best for mute/low volume) | process | endpoint
THEMIS_AUDIO_CAPTURE_MODE=auto
# Auto-boost quiet loopback. Default max gain: 16
# THEMIS_AUDIO_GAIN_MAX=16

# Service
THEMIS_GRPC_PORT=50051
THEMIS_LOG_LEVEL=info

# Use mock speech when keys are missing (default: auto)
# THEMIS_USE_MOCK_SPEECH=true
