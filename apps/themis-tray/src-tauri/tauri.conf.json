{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Themis",
  "version": "0.1.0",
  "identifier": "com.themis.tray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Themis",
        "width": 520,
        "height": 320,
        "minWidth": 400,
        "minHeight": 160,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "mini",
        "title": "Themis Mini",
        "url": "mini.html",
        "width": 52,
        "height": 52,
        "minWidth": 52,
        "minHeight": 52,
        "maxWidth": 52,
        "maxHeight": 52,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "diagnose",
        "title": "Themis Diagnostics",
        "url": "diagnose.html",
        "width": 720,
        "height": 640,
        "minWidth": 520,
        "minHeight": 400,
        "alwaysOnTop": false,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
